# 调试微信代理请求 (仅开发环境(development)支持)
NUXT_DEBUG_MP_REQUEST=false

# 服务端口配置（可改成任意未占用端口）
NUXT_PORT=3000
PORT=3000

# AG-Grid 企业版授权
NUXT_AGGRID_LICENSE=

# KV绑定(本地/docker)
#NITRO_KV_DRIVER=fs
#NITRO_KV_BASE=.data/kv

# SQLite 数据库文件
SQLITE_DB_PATH=.data/sqlite/app.db

# KV绑定(cloudflare)
#NITRO_KV_DRIVER=cloudflare-kv-binding

DEBUG_KEY=

# memory debug and protection
NUXT_DEBUG_MEMORY=false
NUXT_DEBUG_MEMORY_FILE=.data/logs/memory-debug.ndjson
NUXT_DEBUG_MEMORY_MAX_FILE_BYTES=52428800
NUXT_DEBUG_MEMORY_CONSOLE=false
NUXT_DEBUG_MEMORY_BATCH_SYNC_PROGRESS=false
NUXT_DEBUG_MEMORY_ROUTES=false
MP_PROXY_MAX_JSON_BYTES=8388608
MP_PROXY_SOFT_HEAP_MB=3000
MP_APPMESSAGE_CONCURRENCY=1
MP_APPMESSAGE_CHILD_MAX_OLD_SPACE_MB=256
READER_BATCH_SYNC_JOB_TIMEOUT_MS=1800000
READER_BATCH_SYNC_JOB_CHILD_MAX_OLD_SPACE_MB=3072
READER_BATCH_SYNC_ACCOUNT_CHILD_MAX_OLD_SPACE_MB=256
